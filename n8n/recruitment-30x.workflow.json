    {
      "parameters": {
        "sendTo": "={{ $json.body.correo_usuario }}",
        "subject": "Respuesta consulta 30x",
        "message": "=<!doctype html>\n<html lang=\"es\" xmlns=\"http://www.w3.org/1999/xhtml\" xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:o=\"urn:schemas-microsoft-com:office:office\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\n  <meta name=\"color-scheme\" content=\"dark light\" />\n  <meta name=\"supported-color-schemes\" content=\"dark light\" />\n  <title>Nueva consulta · 30X</title>\n  <!--[if mso]>\n  <noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript>\n  <![endif]-->\n  <style>\n    /* Reglas de respaldo. Lo crítico va INLINE (Gmail ignora gran parte de <style>). */\n    body { margin: 0 !important; padding: 0 !important; width: 100% !important; }\n    table { border-collapse: collapse; }\n    img { border: 0; line-height: 100%; outline: none; text-decoration: none; }\n    a { color: #CDFF2E; }\n    @media only screen and (max-width: 620px) {\n      .container { width: 100% !important; }\n      .px { padding-left: 22px !important; padding-right: 22px !important; }\n      .h1 { font-size: 26px !important; }\n    }\n  </style>\n</head>\n\n<body style=\"margin:0; padding:0; background-color:#0A0B08;\">\n\n  <!-- Preheader: texto de vista previa (oculto en el cuerpo) -->\n  <div style=\"display:none; max-height:0; overflow:hidden; mso-hide:all; font-size:1px; line-height:1px; color:#0A0B08;\">\n    Nueva consulta para el Asesor de 30X &#8203;&#8203;&#8203;&#8203;&#8203;&#8203;&#8203;&#8203;\n  </div>\n\n  <!-- Fondo de página (full width) -->\n  <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background-color:#0A0B08;\">\n    <tr>\n      <td align=\"center\" style=\"padding:32px 16px;\">\n\n        <!--[if mso]><table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr><td><![endif]-->\n\n        <!-- Contenedor 600px -->\n        <table role=\"presentation\" class=\"container\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width:600px; max-width:600px; background-color:#14160F; border:1px solid #262A20; border-radius:14px; overflow:hidden;\">\n\n          <!-- Barra de acento superior (lima) -->\n          <tr>\n            <td style=\"height:4px; line-height:4px; font-size:0; background-color:#CDFF2E;\">&nbsp;</td>\n          </tr>\n\n          <!-- Header: wordmark 30X + badge -->\n          <tr>\n            <td class=\"px\" style=\"padding:24px 32px 18px 32px; border-bottom:1px solid #262A20;\">\n              <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                <tr>\n                  <td align=\"left\" style=\"font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; font-size:24px; font-weight:bold; letter-spacing:-0.5px; color:#F2F4EC;\">\n                    30<span style=\"color:#CDFF2E;\">X</span>\n                  </td>\n                  <td align=\"right\" style=\"font-family:'Courier New',Courier,monospace; font-size:11px; letter-spacing:1px; text-transform:uppercase; color:#CDFF2E;\">\n                    <span style=\"display:inline-block; padding:6px 11px; background-color:rgba(205,255,46,0.10); border:1px solid #3A4A12; border-radius:999px;\">● Nueva consulta</span>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- Cuerpo -->\n          <tr>\n            <td class=\"px\" style=\"padding:30px 32px 12px 32px;\">\n              <p style=\"margin:0 0 8px 0; font-family:'Courier New',Courier,monospace; font-size:11px; letter-spacing:2px; text-transform:uppercase; color:#8E9384;\">\n                Asesor &middot; 30X\n              </p>\n              <h1 class=\"h1\" style=\"margin:0 0 10px 0; font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; font-size:30px; line-height:1.1; font-weight:bold; letter-spacing:-0.5px; color:#F2F4EC;\">\n                Llegó una nueva consulta\n              </h1>\n              <p style=\"margin:0 0 24px 0; font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; font-size:15px; line-height:1.55; color:#8E9384;\">\n                Esto es lo que escribió la persona. Respondé directamente a este correo para contestarle: {{ $json.body.correo_usuario }}.\n              </p>\n            </td>\n          </tr>\n\n          <!-- ╔══════════════════════════════════════════════════════╗\n               ║  CONSULTA — acá entra la variable de n8n:            ║\n               ║      {{ $json.body.consulta }}                       ║\n               ╚══════════════════════════════════════════════════════╝ -->\n          <tr>\n            <td class=\"px\" style=\"padding:0 32px 4px 32px;\">\n              <p style=\"margin:0 0 10px 0; font-family:'Courier New',Courier,monospace; font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:#CDFF2E;\">\n                Consulta\n              </p>\n            </td>\n          </tr>\n          <tr>\n            <td class=\"px\" style=\"padding:0 32px 30px 32px;\">\n              <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background-color:#1C1F16; border:1px solid #262A20; border-left:3px solid #CDFF2E; border-radius:10px;\">\n                <tr>\n                  <td style=\"padding:18px 20px; font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; font-size:16px; line-height:1.6; color:#F2F4EC; white-space:pre-wrap;\">{{ $json.body.consulta }}</td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- ╔══════════════════════════════════════════════════════╗\n               ║  CONTEXTO — acá entra la variable de n8n:            ║\n               ║      {{ $json.body.contexto_conversacion }}          ║\n               ╚══════════════════════════════════════════════════════╝ -->\n          <tr>\n            <td class=\"px\" style=\"padding:0 32px 4px 32px;\">\n              <p style=\"margin:0 0 10px 0; font-family:'Courier New',Courier,monospace; font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:#CDFF2E;\">\n                Contexto\n              </p>\n            </td>\n          </tr>\n          <tr>\n            <td class=\"px\" style=\"padding:0 32px 30px 32px;\">\n              <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background-color:#1C1F16; border:1px solid #262A20; border-left:3px solid #CDFF2E; border-radius:10px;\">\n                <tr>\n                  <td style=\"padding:18px 20px; font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; font-size:16px; line-height:1.6; color:#F2F4EC; white-space:pre-wrap;\">{{ $json.body.contexto_conversacion }}</td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- Footer -->\n          <tr>\n            <td class=\"px\" style=\"padding:20px 32px 26px 32px; border-top:1px solid #262A20; background-color:#101208;\">\n              <p style=\"margin:0; font-family:'Courier New',Courier,monospace; font-size:11px; line-height:1.6; letter-spacing:0.5px; color:#6E7363;\">\n                30X &middot; Asesor &nbsp;&middot;&nbsp; correo generado automáticamente\n              </p>\n            </td>\n          </tr>\n\n        </table>\n\n        <!--[if mso]></td></tr></table><![endif]-->\n\n      </td>\n    </tr>\n  </table>\n\n</body>\n</html>",
